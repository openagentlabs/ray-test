{
  "name": "file-system-client",
  "version": "0.1.0",
  "description": "High-performance text and binary file I/O with Result-based error handling.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run testing/unit",
    "test:integration": "vitest run testing/integration",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "neverthrow": "^8.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
