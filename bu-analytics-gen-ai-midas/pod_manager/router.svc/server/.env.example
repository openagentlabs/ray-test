# Copy to .env beside app_config.toml (same directory). Loaded on startup before config merge.
# Every app_config.toml leaf can be overridden; canonical names use POD_MANAGER_<SECTION>_<FIELD>.
# Legacy SOLUTIONS_* names (and a few aliases below) still work — see config_env.LEGACY_ENV_ALIASES.

# --- [app] ---
POD_MANAGER_APP_SERVICE_NAME=router-svc
POD_MANAGER_APP_LOG_LEVEL=DEBUG
# Aliases: LOG_LEVEL, SOLUTIONS_APP_LOG_LEVEL, SOLUTIONS_LOG_LEVEL

# --- [api_service] ---
POD_MANAGER_API_SERVICE_HOST=0.0.0.0
POD_MANAGER_API_SERVICE_PORT=8804
# Aliases: SOLUTIONS_API_SERVICE_HOST, SOLUTIONS_SERVICE_GRPC_HOST
#          SOLUTIONS_API_SERVICE_PORT, SOLUTIONS_SERVICE_GRPC_PORT

# --- [postgres] ---
# Shared backend Postgres. DATABASE_URL is the alias for [postgres].dsn (same var the backend uses).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/midas
# Or set the canonical key directly: POD_MANAGER_POSTGRES_DSN=...
POD_MANAGER_POSTGRES_TABLE_PREFIX=pm_
POD_MANAGER_POSTGRES_POOL_MIN=1
POD_MANAGER_POSTGRES_POOL_MAX=10
POD_MANAGER_POSTGRES_COMMAND_TIMEOUT_SEC=10.0

# --- paths (not in app_config.toml) ---
# SOLUTIONS_APP_CONFIG_PATH=app_config.toml

# --- AWS (CloudWatch logging only; not used for the database) ---
# AWS_REGION=us-east-1
