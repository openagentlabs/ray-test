{
  "name": "@router/client-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/gen"
  ],
  "scripts": {
    "proto:gen": "bash tools/generate_protos.sh",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@grpc/grpc-js": "^1.12.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "ts-proto": "^2.6.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
