# Local Docker Compose deploy profile — source before CLI or copy into client .env files.
POD_MANAGER_DEPLOY_TARGET=local
ENVOY_URL=http://localhost:10000
NEXT_PUBLIC_ENVOY_URL=http://localhost:10000
POD_MANAGER_HOST=localhost
POD_MANAGER_PORT=8804
POD_MANAGER_GRPC_HOST=localhost
POD_MANAGER_GRPC_PORT=8804
# Shared Postgres for the local stack (matches docker-compose.local.yml).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/midas
POD_MANAGER_POSTGRES_TABLE_PREFIX=pm_
