aws_region   = "us-east-1"
environment  = "dev"
service_name = "router-svc"

# Set create_vpc=false and supply IDs when at VPC quota:
# create_vpc                  = false
# existing_vpc_id             = "vpc-xxxxxxxx"
# existing_private_subnet_ids = ["subnet-aaa", "subnet-bbb"]

eks_cluster_version     = "1.29"
eks_node_instance_types = ["t3.medium"]
eks_node_desired_size   = 2
eks_node_min_size       = 2
eks_node_max_size       = 4

kubernetes_namespace       = "routing"
kubernetes_service_account = "pod-manager"

# Routing-tier tables live in the shared backend Postgres with this prefix.
db_table_prefix = "pm_"

# Optional: Secrets Manager ARN holding the shared DATABASE_URL.
# Leave empty to inject the DSN via a Kubernetes Secret instead.
# database_url_secret_arn = "arn:aws:secretsmanager:us-east-1:<acct>:secret:pod-manager-db-xxxx"
