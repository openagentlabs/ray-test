# Copy to backend.tf and set your remote state bucket (recommended for teams).
#
#   cp backend.tf.example backend.tf
#   terraform init -migrate-state

terraform {
  backend "s3" {
    bucket         = "your-terraform-state-bucket"
    key            = "pod-manager/dev/terraform.tfstate"
    region         = "us-east-1"
    encrypt        = true
    dynamodb_table = "terraform-state-lock" # optional lock table
  }
}
