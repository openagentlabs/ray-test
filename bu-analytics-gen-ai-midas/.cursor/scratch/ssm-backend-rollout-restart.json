{
  "commands": [
    "set -e",
    "export AWS_DEFAULT_REGION=us-east-1",
    "export KUBECONFIG=/root/.kube/config",
    "aws eks update-kubeconfig --region us-east-1 --name midas-eks-dev",
    "echo '=== Before ==='",
    "kubectl get pods -n midas-apps -l app.kubernetes.io/name=midas-api-backend-svc -o wide",
    "echo ''",
    "echo '=== rollout restart deployment/midas-api-backend-svc ==='",
    "kubectl rollout restart deployment/midas-api-backend-svc -n midas-apps",
    "echo ''",
    "echo '=== Waiting for rollout (timeout 180s) ==='",
    "kubectl rollout status deployment/midas-api-backend-svc -n midas-apps --timeout=180s",
    "echo ''",
    "echo '=== After ==='",
    "kubectl get pods -n midas-apps -l app.kubernetes.io/name=midas-api-backend-svc -o wide",
    "kubectl get rs -n midas-apps -l app.kubernetes.io/name=midas-api-backend-svc -o wide 2>/dev/null || true"
  ]
}
