#!/usr/bin/env bash
set -euo pipefail

#
# jp-commit-push
# -------------
# "Gold standard" pull → commit → push helper for the current git branch.
#
# Safety contract:
# - Pull first (repo-configured strategy).
# - Stop immediately on any error or merge conflict.
# - Never force push; never amend; never bypass hooks.
# - Require an explicit commit subject (prompt or --subject).
#

usage() {
  cat <<'USAGE'
jp-commit-push — pull, stage, commit, push (safe defaults)

Usage:
  ./.cursor/scripts/jp-commit-push [--all | --paths <p1> [<p2> ...]] [--subject "msg"] [--body "text"] [--yes]

Staging:
  --all                 Stage all changes (git add -A).
  --paths <...>         Stage only the given paths (repeatable).
  (default)             If nothing is staged, the command will stop and ask you to stage via --all/--paths.

Commit message:
  --subject "..."       Commit subject line. If omitted, you'll be prompted.
  --body "..."          Optional commit body. If omitted, you can enter a body interactively.
  --yes                 Non-interactive: requires --subject; skips confirmation prompts.

Examples:
  ./.cursor/scripts/jp-commit-push --all
  ./.cursor/scripts/jp-commit-push --paths docs/README.md deploy/ecs-app --subject "docs: update runbook"
  ./.cursor/scripts/jp-commit-push --all --subject "docs: refresh diagrams" --yes
USAGE
}

die() {
  echo "[ERROR] $*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

conflict_table() {
  # Prints a compact conflict table based on porcelain status codes.
  # This intentionally does not attempt any resolution.
  local repo_root="$1"
  (cd "$repo_root" && {
    local lines
    lines="$(git status --porcelain || true)"
    local conflicts
    conflicts="$(echo "$lines" | awk '$1 ~ /^(UU|AA|DD|AU|UA|DU|UD)$/ {print $1 "\t" substr($0,4)}')"

    if [[ -z "$conflicts" ]]; then
      return 0
    fi

    echo
    echo "| # | Path | Conflict type | Ours (HEAD) | Theirs (incoming) | Base (common ancestor) | Suggested action (for user to choose) |"
    echo "|---|------|---------------|-------------|-------------------|------------------------|---------------------------------------|"

    local i=0
    while IFS=$'\t' read -r code path; do
      [[ -z "${code:-}" ]] && continue
      i=$((i + 1))

      local ctype
      case "$code" in
        UU) ctype="both modified" ;;
        AA) ctype="both added" ;;
        DD) ctype="both deleted" ;;
        AU) ctype="added by us" ;;
        UA) ctype="added by them" ;;
        DU) ctype="deleted by us" ;;
        UD) ctype="deleted by them" ;;
        *) ctype="$code" ;;
      esac

      # These may fail if the index stages don't exist for this path; keep output short.
      local ours theirs base
      ours="$(git show ":2:$path" 2>/dev/null | head -n 1 | tr -d '\r' || true)"
      theirs="$(git show ":3:$path" 2>/dev/null | head -n 1 | tr -d '\r' || true)"
      base="$(git show ":1:$path" 2>/dev/null | head -n 1 | tr -d '\r' || true)"
      [[ -z "$ours" ]] && ours="(unavailable)"
      [[ -z "$theirs" ]] && theirs="(unavailable)"
      [[ -z "$base" ]] && base="(unavailable)"

      echo "| $i | \`$path\` | $ctype | ${ours//|/\\|} | ${theirs//|/\\|} | ${base//|/\\|} | manual merge / choose ours / choose theirs |"
    done <<< "$conflicts"
    echo
    echo "Conflicts detected. No resolution was attempted."
  })
}

main() {
  require_cmd git
  require_cmd awk

  local stage_mode="none"
  local -a stage_paths=()
  local subject=""
  local body=""
  local assume_yes="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      --all)
        stage_mode="all"
        shift
        ;;
      --paths)
        stage_mode="paths"
        shift
        while [[ $# -gt 0 && "$1" != --* ]]; do
          stage_paths+=("$1")
          shift
        done
        ;;
      --subject)
        shift
        subject="${1:-}"
        shift
        ;;
      --body)
        shift
        body="${1:-}"
        shift
        ;;
      --yes)
        assume_yes="true"
        shift
        ;;
      *)
        die "Unknown arg: $1 (use --help)"
        ;;
    esac
  done

  local repo_root
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  [[ -n "$repo_root" ]] || die "Not inside a git repository."

  cd "$repo_root"

  local branch
  branch="$(git rev-parse --abbrev-ref HEAD)"
  [[ "$branch" != "HEAD" ]] || die "Detached HEAD. Check out a branch before running this command."

  echo "[INFO] Repo   : $repo_root"
  echo "[INFO] Branch : $branch"

  echo
  echo "[INFO] Pulling latest changes (repo-configured strategy)..."
  if ! git pull; then
    echo
    die "git pull failed. Fix the issue and re-run."
  fi

  # Stop immediately if pull introduced conflicts.
  if git status --porcelain | awk '$1 ~ /^(UU|AA|DD|AU|UA|DU|UD)$/ {exit 10}'; then
    :
  else
    echo
    echo "[ERROR] Merge conflicts detected after pull."
    conflict_table "$repo_root" || true
    exit 1
  fi

  echo
  echo "[INFO] Working tree summary:"
  git status -sb

  case "$stage_mode" in
    all)
      echo
      echo "[INFO] Staging all changes (git add -A)..."
      git add -A
      ;;
    paths)
      if [[ ${#stage_paths[@]} -eq 0 ]]; then
        die "--paths was provided but no paths were given."
      fi
      echo
      echo "[INFO] Staging selected paths:"
      for p in "${stage_paths[@]}"; do
        echo "  - $p"
      done
      git add -- "${stage_paths[@]}"
      ;;
    none)
      # leave as-is; require something staged
      ;;
    *)
      die "Internal error: unknown stage mode '$stage_mode'"
      ;;
  esac

  if git diff --cached --quiet; then
    echo
    echo "[ERROR] Nothing staged to commit."
    echo "Stage changes with either:"
    echo "  - --all"
    echo "  - --paths <p1> [<p2> ...]"
    exit 1
  fi

  if [[ -z "$subject" ]]; then
    if [[ "$assume_yes" == "true" ]]; then
      die "--yes requires --subject."
    fi
    echo
    read -r -p "Commit subject (imperative, <= ~72 chars): " subject
    [[ -n "$subject" ]] || die "Commit subject cannot be empty."
  fi

  if [[ -z "$body" && "$assume_yes" != "true" ]]; then
    echo
    echo "Optional commit body. Finish with an empty line."
    echo "(Press Enter immediately to skip.)"
    local tmp_body=""
    while IFS= read -r line; do
      [[ -z "$line" ]] && break
      tmp_body+="${line}"$'\n'
    done
    body="${tmp_body%$'\n'}"
  fi

  echo
  echo "[INFO] Proposed commit message:"
  echo "  $subject"
  if [[ -n "$body" ]]; then
    echo
    while IFS= read -r ln; do
      echo "  $ln"
    done <<< "$body"
  fi

  if [[ "$assume_yes" != "true" ]]; then
    echo
    read -r -p "Commit and push? [y/N] " ans
    case "${ans:-}" in
      y|Y|yes|YES) ;;
      *) die "Aborted by user." ;;
    esac
  fi

  echo
  echo "[INFO] Committing..."
  if [[ -n "$body" ]]; then
    git commit -m "$subject" -m "$body"
  else
    git commit -m "$subject"
  fi

  local sha
  sha="$(git rev-parse --short HEAD)"

  echo
  echo "[INFO] Pushing..."
  if ! git push; then
    echo
    die "git push failed. No further actions were taken."
  fi

  echo
  echo "[OK] Done."
  echo "  Subject : $subject"
  echo "  Commit  : $sha"
  echo "  Branch  : $branch"
}

main "$@"

