[submodule "ai_gateway"]
	path = ai_gateway
	url = https://ucgithub.exlservice.com/Unified-Cloud-DevOps/bu-digital-exlerate-aigateway.git
	branch = develop
	# fetch-only: pushurl is DISABLED in .git/modules/ai_gateway/config
