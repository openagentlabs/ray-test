# REFERENCE ONLY — do not kubectl apply.
# Authoritative TargetGroupBindings are managed by Terraform (deploy/ecs-app/eks-tgb.tf).
# Applying this file manually will overwrite Terraform state and cause drift.
#
# TargetGroupBinding for midas-web-frontend-svc
#
# This binds the Terraform-managed ALB target group to the frontend Kubernetes
# Service. The AWS Load Balancer Controller watches the Service's Endpoints and
# automatically calls RegisterTargets / DeregisterTargets on the target group as
# pods are created, replaced, or deleted (scale events, rollouts, etc.).
#
# Prerequisites:
#   1. AWS Load Balancer Controller installed in the cluster (see
#      deploy/k8s/aws-load-balancer-controller/README.md)
#   2. Terraform applied with alb_nlb_enabled=true so the target group exists
#   3. Substitute the real TG ARN from: terraform output alb_frontend_target_group_arn
#
# Verify:
#   kubectl get targetgroupbinding midas-frontend-tgb -n midas-apps -o yaml
#   # Look for status.observedGeneration matching metadata.generation
#
# ALB path routing (HTTPS via NLB → ALB):
#   https://Exldecision-ai-dev.exlservice.com/frontend     → frontend pod GET /
#   https://Exldecision-ai-dev.exlservice.com/frontend/*   → frontend pod GET /*  (assets, routes)
#   The ALB url-rewrite transform strips /frontend before forwarding HTTP to pod port 8080.

apiVersion: elbv2.k8s.aws/v1beta1
kind: TargetGroupBinding
metadata:
  name: midas-frontend-tgb
  namespace: midas-apps
spec:
  serviceRef:
    name: midas-web-frontend-svc
    port: 8080
  targetGroupARN: "arn:aws:elasticloadbalancing:us-east-1:811391286931:targetgroup/midas-dev-alb-fe-tg/bfc3d790d15820e5"
  targetType: ip
