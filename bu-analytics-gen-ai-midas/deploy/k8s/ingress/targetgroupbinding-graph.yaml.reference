# REFERENCE ONLY — do not kubectl apply.
# Authoritative TargetGroupBindings are managed by Terraform (deploy/ecs-app/eks-tgb.tf).
# Applying this file manually will overwrite Terraform state and cause drift.
#
# TargetGroupBinding for midas-graph-svc
#
# This binds the Terraform-managed ALB target group to the graph Kubernetes
# Service. The AWS Load Balancer Controller watches the Service's Endpoints and
# automatically calls RegisterTargets / DeregisterTargets on the target group as
# pods are created, replaced, or deleted (scale events, rollouts, etc.).
#
# Prerequisites:
#   1. AWS Load Balancer Controller installed in the cluster (see
#      deploy/k8s/aws-load-balancer-controller/README.md)
#   2. Terraform applied with alb_nlb_enabled=true so the target group exists
#   3. Substitute the real TG ARN from: terraform output alb_graph_target_group_arn
#
# Apply:
#   kubectl apply -f deploy/k8s/ingress/targetgroupbinding-graph.yaml -n midas-apps
#
# Verify:
#   kubectl get targetgroupbinding midas-graph-tgb -n midas-apps -o yaml
#
# ALB path routing:
#   http://<ALB-DNS>/graph/health    → graph pod GET /health
#   http://<ALB-DNS>/graph/query     → graph pod POST /query
#   http://<ALB-DNS>/graph/status    → graph pod GET /status
#   The ALB url-rewrite transform strips /graph before forwarding to port 8001.

apiVersion: elbv2.k8s.aws/v1beta1
kind: TargetGroupBinding
metadata:
  name: midas-graph-tgb
  namespace: midas-apps
spec:
  serviceRef:
    name: midas-graph-svc
    port: 8001
  targetGroupARN: "arn:aws:elasticloadbalancing:us-east-1:811391286931:targetgroup/midas-dev-alb-gr-tg/6676c1d60c4332e5"
  targetType: ip
