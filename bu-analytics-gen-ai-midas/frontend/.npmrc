# Install OS-specific optional deps on this machine (e.g. Rollup native binaries, fsevents on macOS).
# If node_modules was copied from another OS, delete it and run `npm install` again — do not copy node_modules between Windows and Mac.

# Enforce strict peer dependency resolution so mismatches fail loudly on local
# installs (same behaviour as `npm ci` inside Docker). This prevents the class
# of bug where a developer silently installs a broken lockfile that only breaks
# in CI (e.g. cross-major vitest/@vitest/coverage-v8 version mismatch).
legacy-peer-deps=false

# Honour the "engines": { "node": ">=18" } constraint in package.json locally,
# consistent with the node:20-alpine Docker builder image.
engine-strict=true
