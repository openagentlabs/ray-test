# MIDAS frontend environment variables.
# Copy to `.env` and fill in the values for your environment.

# Base URL of the FastAPI backend (must include scheme; no trailing slash).
VITE_BASE_URL=http://localhost:8000

# ---- AWS Cognito (Hosted UI + Microsoft Entra ID federation) ----
# All VITE_* values are PUBLIC — they are baked into the built JS bundle.
# NEVER put the Cognito client secret here; it lives on the backend only.

# Fully-qualified Cognito domain (no trailing slash). Example:
#   https://midas.auth.us-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=https://<your-cognito-domain>

# The public app-client id for the React app.
VITE_COGNITO_CLIENT_ID=<your-cognito-app-client-id>

# Must exactly match one of the callback URLs configured on the Cognito app client
# AND one of COGNITO_REDIRECT_URIS on the backend.
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback

# Where Cognito sends the user after /logout (must be registered as a sign-out URL
# on the Cognito app client).
VITE_COGNITO_LOGOUT_REDIRECT_URI=http://localhost:5173/

# Space-separated scopes. Defaults are usually fine.
VITE_COGNITO_SCOPES=openid email profile
