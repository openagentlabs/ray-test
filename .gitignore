# ray-test — repository-wide ignores
# Remote: https://github.com/openagentlabs/test001.git
# https://help.github.com/articles/ignoring-files/

# =============================================================================
# Operating system
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Editors & IDEs
# =============================================================================
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# Secrets & environment (never commit real credentials)
# =============================================================================
.env*
!.env.example
!**/.env.example

# AWS / deploy env files with credentials
infra/envs/**/.env.aws
**/secrets.auto.tfvars
*.auto.tfvars
*.auto.tfvars.json

# =============================================================================
# Node.js — Next.js apps (aspire.svc/, manager-web/, frontend/, clients/**/ts)
# =============================================================================
node_modules/
**/node_modules/

.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.next/
**/.next/
out/
**/out/

dist/
**/dist/
build/
**/build/
.turbo/
.vite/
*.tsbuildinfo

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

.vercel

coverage/
**/coverage/
.vitest/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# =============================================================================
# Python — tools, clients, *.svc/, deploy scripts
# =============================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python

.venv/
**/.venv/
venv/
**/venv/
ENV/
env/

*.egg
*.egg-info/
**/*.egg-info/
.eggs/
**/.eggs/

.mypy_cache/
**/.mypy_cache/
.ruff_cache/
**/.ruff_cache/
.pytype/
.pyre/

.pytest_cache/
**/.pytest_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

.uv/
.python-version

*.db
*.sqlite
*.sqlite3

