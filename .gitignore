# Cursor — machine-local (commit .cursor/rules/, .cursor/skills/, templates/)
# =============================================================================
.cursor/mcp.json
.cursor/scratch/

# =============================================================================
# Local runtime — apps and services
# =============================================================================
aspire.svc/service-registry.sqlite
aspire.svc/.aspire/

# =============================================================================
# Terraform / OpenTofu — runnable root: infra/aws/aws_tf/
# =============================================================================
.terraform/
**/.terraform/

*.tfstate
*.tfstate.*
crash.log
crash.*.log

override.tf
override.tf.json
*_override.tf
*_override.tf.json
**/terraform.tfvars.local
**/terraform.tfvars.*.local

# Plan artifacts
**/tfplan
*.tfplan
infra/aws/aws_tf/*.log

# Legacy path (if present locally)
infra/aws_tf/

# =============================================================================
# Deploy / build artifacts
# =============================================================================
*.log
!**/.gitkeep
*.pem
*.key
*.p12
*.pfx
credentials.json
**/secrets.json

# Checkov / scanner output (local runs)
checkov-results.*
*.sarif

# =============================================================================
# Misc
