# ray-test — repository-wide ignores
# https://help.github.com/articles/ignoring-files/

# =============================================================================
# Operating system
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Editors & IDEs
# =============================================================================
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# =============================================================================
# Secrets & environment (never commit real credentials)
# =============================================================================
.env*
!.env.example
!**/.env.example

# =============================================================================
# Node.js — aspire.svc/ (Next.js / Vitest)
# =============================================================================
node_modules/
**/node_modules/

.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
**/.next/
out/
**/out/

# Build / bundler output
dist/
**/dist/
build/
**/build/
.turbo/
.vite/
*.tsbuildinfo

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Vercel
.vercel

# Test runners (Vitest / Playwright)
coverage/
**/coverage/
.vitest/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# =============================================================================
# Python — .cursor/tools/aspire/ (uv-managed CLI)
# =============================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python

.venv/
**/.venv/
venv/
**/venv/
ENV/
env/

# Packaging / installers
*.egg
*.egg-info/
**/*.egg-info/
.eggs/
**/.eggs/

# Type checkers & linters
.mypy_cache/
**/.mypy_cache/
.ruff_cache/
**/.ruff_cache/
.pytype/
.pyre/

# Test & coverage (Python)
.pytest_cache/
**/.pytest_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# uv local cache (commit uv.lock under .cursor/tools/aspire/)
.uv/

# pyenv local version pin (per-machine)
.python-version

# Local SQLite databases (service registry, tool DBs)
*.db
*.sqlite
*.sqlite3

# =============================================================================
# Cursor — machine-local (commit .cursor/rules/, .cursor/skills/, templates/)
# =============================================================================
.cursor/mcp.json

# Agent scratch: make logs, terraform apply output, ad-hoc test runs
.cursor/scratch/

# =============================================================================
# Arb Aspire — local runtime (aspire.svc/)
# =============================================================================
aspire.svc/service-registry.sqlite
aspire.svc/.aspire/

# =============================================================================
# Terraform / OpenTofu — runnable root: infra/aws_tf/
# =============================================================================
.terraform/
**/.terraform/

*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Local overrides (never commit engineer-specific variable files)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
**/terraform.tfvars.local
**/terraform.tfvars.*.local

# Auto-loaded var files are for secrets (e.g. secrets.auto.tfvars from scaffold_secrets.py)
*.auto.tfvars
*.auto.tfvars.json
infra/envs/**/secrets.auto.tfvars

# Plan artifacts
infra/aws_tf/tfplan
**/tfplan
*.tfplan

# Terraform run logs (local apply/destroy output)
infra/aws_tf/*.log

# =============================================================================
# Misc logs & certs
# =============================================================================
*.log
!**/.gitkeep
*.pem
*.key
*.p12
*.pfx
credentials.json
**/secrets.json
