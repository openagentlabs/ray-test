# Copy to infra/local-docker-compose/.env.local for compose-level overrides (gitignored).
# Per-service AWS credentials: infra/envs/dev/.env.aws (shared by all containers).
# Per-service secrets: */server/.env.local (see each service README).

AWS_DEFAULT_REGION=us-east-1

# Optional: override frontend auth for container runs (generate a strong secret for real use)
# AUTH_SECRET=
