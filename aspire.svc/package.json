{
  "name": "arb_sherpa",
  "version": "0.1.0",
  "private": true,
  "description": "Arb Aspire — Next.js application host: composes UI, aspire.svc/lib platform code, and microservice-shaped aspire.svc/services/* with observability and strict boundaries (intent aligned with Microsoft .NET Aspire’s app model; not the .NET SDK).",
  "scripts": {
    "dev": "NODE_ENV=development next dev --port 8801 --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "boot:init": "node scripts/booter.mjs init",
    "boot:list": "node scripts/booter.mjs list",
    "boot:search": "node scripts/booter.mjs search",
    "boot:status": "node scripts/booter.mjs status",
    "boot:start": "node scripts/booter.mjs start",
    "boot:stop": "node scripts/booter.mjs stop",
    "sync:cloudwatch-logging": "node ../infra/aws_tf/scripts/sync-cloudwatch-logging-defaults.mjs",
    "sync:terraform-outputs": "node ../infra/aws_tf/scripts/sync-cloudwatch-logging-defaults.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1048.0",
    "@arb/iam-service-client": "file:../iam.svc/client",
    "@base-ui/react": "^1.4.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "better-sqlite3": "^11.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.0.5"
  }
}
